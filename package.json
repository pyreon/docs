    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitus-labs/tools-lint": "^1.15.4",
    "fumadocs-docgen": "^3.0.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
